# Public hostname of the application.
# Used by Caddy for automatic HTTPS (Let's Encrypt) and by Django (CSRF, emails).
#
# Copy this file to .env and set your domain before running docker compose:
#
#   cp .env.example .env
#   # edit .env
#   ./docker-prepare.sh
#   docker compose -f docker-compose.yml -f docker-compose.https.yml up -d

DOMAIN=your.fqdn.example
